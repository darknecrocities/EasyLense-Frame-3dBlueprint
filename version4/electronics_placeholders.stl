        vertex -0.5 0.5 -0.5
        vertex 0.5 0.5 -0.5
        vertex 0.5 -0.5 -0.5
    endloop
endfacet
facet normal 0 0 1
    outer loop
        vertex -0.5 -0.5 0.5
        vertex 0.5 -0.5 0.5
        vertex -0.5 0.5 0.5
    endloop
endfacet
facet normal -0 0 1
    outer loop
        vertex -0.5 0.5 0.5
        vertex 0.5 -0.5 0.5
        vertex 0.5 0.5 0.5
    endloop
endfacet
endsolid unnamed
